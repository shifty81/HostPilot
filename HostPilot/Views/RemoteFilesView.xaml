<UserControl x:Class="HostPilot.Views.RemoteFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Remote File Browser" FontSize="18" FontWeight="Bold" />
        </DockPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridCheckBoxColumn Header="Dir" Binding="{Binding IsDirectory}" Width="Auto"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes}" Width="*"/>
                <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedUtc}" Width="*"/>
                <DataGridTextColumn Header="Relative Path" Binding="{Binding RelativePath}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="{Binding CurrentPath}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
