<Window x:Class="HostPilot.Dialogs.ModImportReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review Mod Imports" Height="520" Width="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Pending Imports">
            <ListView Name="ImportListView">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="220"/>
                        <GridViewColumn Header="Detected Type" Width="120"/>
                        <GridViewColumn Header="Target" Width="160"/>
                        <GridViewColumn Header="Warnings" Width="280"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Margin="0,0,8,0" Content="Cancel" IsCancel="True"/>
            <Button Width="140" Content="Install Selected" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
