<Window x:Class="HostPilot.Dialogs.ImportDiscoveredServersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Existing Servers"
        Height="620"
        Width="1080"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource DarkBgBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Import Existing Dedicated Servers" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="We found dedicated servers already installed on this PC. Choose which ones HostPilot should onboard without reinstalling them." 
                       Margin="0,6,0,0" TextWrapping="Wrap"/>
            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedCount, StringFormat=Selected for import: {0}}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Candidates}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Import" Binding="{Binding IsSelected, Mode=TwoWay}" Width="80"/>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="180"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ServerType}" Width="140"/>
                <DataGridTextColumn Header="Install Path" Binding="{Binding InstallPath}" Width="*"/>
                <DataGridTextColumn Header="Executable" Binding="{Binding ExecutablePath}" Width="220"/>
                <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat=F2}" Width="90"/>
                <DataGridCheckBoxColumn Header="Already Imported" Binding="{Binding IsAlreadyImported}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Skip Import" Width="120" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Import Selected" Width="160" IsDefault="True" Click="OnImportClicked"/>
        </StackPanel>
    </DockPanel>
</Window>
