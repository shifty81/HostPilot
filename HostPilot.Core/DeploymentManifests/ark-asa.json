{
  "id": "ark-asa",
  "displayName": "ARK: Survival Ascended",
  "icon": "\ud83e\udd95",
  "tier": "A",
  "distribution": "steamcmd",
  "appId": 2430930,
  "defaultDir": "ark_sa",
  "executable": "ArkAscendedServer.exe",
  "launchArgsTemplate": "{MapName}?listen?SessionName=\"{ServerName}\"?Port={GamePort}?QueryPort={QueryPort} -server -log",
  "configFiles": [
    "ShooterGame/Saved/Config/WindowsServer/GameUserSettings.ini",
    "ShooterGame/Saved/Config/WindowsServer/Game.ini"
  ],
  "ports": [
    {
      "name": "GamePort",
      "default": 7777,
      "protocol": "udp"
    },
    {
      "name": "QueryPort",
      "default": 27015,
      "protocol": "udp"
    },
    {
      "name": "RconPort",
      "default": 27020,
      "protocol": "tcp"
    }
  ],
  "fields": [
    {
      "key": "ServerName",
      "type": "string",
      "default": "My ARK ASA Server",
      "required": true
    },
    {
      "key": "MapName",
      "type": "string",
      "default": "TheIsland_WP",
      "required": true
    },
    {
      "key": "MaxPlayers",
      "type": "number",
      "default": "70",
      "required": false
    }
  ],
  "cluster": {
    "supported": true,
    "sharedFields": [
      "ClusterId"
    ],
    "perNodeFields": [
      "GamePort",
      "QueryPort"
    ]
  },
  "discovery": {
    "executables": [
      "ArkAscendedServer.exe"
    ],
    "files": [
      "GameUserSettings.ini",
      "Game.ini"
    ],
    "folders": [
      "ark_sa",
      "ARK: Survival Ascended"
    ],
    "confidence": 0.75
  },
  "notes": [
    "ARK cluster setups should synchronize cluster ID and shared storage path."
  ]
}