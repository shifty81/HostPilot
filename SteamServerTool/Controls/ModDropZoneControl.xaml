<UserControl x:Class="SteamServerTool.Controls.ModDropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="160"
             AllowDrop="True">
    <Border Margin="8"
            Padding="18"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#505050"
            Background="#1B1B1B">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Drop mod files, zip archives, or folders here"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Supported content is controlled by the selected server template."
                       Foreground="#BFBFBF"
                       HorizontalAlignment="Center"/>
            <WrapPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="Add Local Mod" Margin="4" Padding="14,6"/>
                <Button Content="Import Zip" Margin="4" Padding="14,6"/>
                <Button Content="Import Folder" Margin="4" Padding="14,6"/>
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
